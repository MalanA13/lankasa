#!/usr/bin/env bash

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
ROOT_DIR="$(dirname "$(dirname "$SCRIPT_PATH")")"

ENGINE_DIR="$ROOT_DIR/engine"

COMMAND="$1"
shift

case "$COMMAND" in

    apply)
        "$ENGINE_DIR/apply.sh" "$@"
        ;;

    validate)
        "$ENGINE_DIR/validate.sh" "$@"
        ;;

    reload)
        "$ENGINE_DIR/reload.sh"
        ;;

    current)
        "$ENGINE_DIR/current.sh"
        ;;

    list)
        "$ENGINE_DIR/list.sh"
        ;;

    info)
        "$ENGINE_DIR/info.sh" "$@"
        ;;

    new)
        "$ENGINE_DIR/new.sh" "$@"
        ;;

    health)
        "$ENGINE_DIR/health.sh"
        ;;

    *)
        cat <<EOF
Lankasa CLI

Usage:
  lankasa apply <theme>
  lankasa validate <theme>
  lankasa reload
  lankasa current
  lankasa list
  lankasa info <theme>
  lankasa new <theme>
  lankasa health
EOF
        exit 1
        ;;
esac
